{
  "name": "text-rpg-server",
  "version": "1.0.0",
  "description": "文字回合制挂机游戏后端",
  "main": "dist/app.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --watch src src/app.ts",
    "build": "tsc",
    "start": "node dist/app.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "lint": "eslint src",
    "lint:dup": "jscpd ../client src --config ../.jscpd.json",
    "lint:dep": "depcruise src --config ../.dependency-cruiser.cjs --output-type err",
    "lint:channel": "node ../scripts/check-data-channel.js",
    "lint:all": "npm run lint && npm run lint:dup && npm run lint:dep && npm run lint:channel",
    "test:all": "npm run test && node ../scripts/test-gm-apis.js && node ../scripts/test-player-apis.js",
    "test:api": "node ../scripts/test-gm-apis.js && node ../scripts/test-player-apis.js",
    "test:ws": "node ../scripts/test-websocket.js",
    "test:verify-db": "node ../scripts/verify-init-mongodb.js",
    "test:full": "node ../scripts/test-all.js"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "axios": "^1.13.6",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.2",
    "mongodb": "^6.0.0",
    "ws": "^8.14.2"
  },
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/node": "^20.10.5",
    "@types/ws": "^8.5.10",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "dependency-cruiser": "^17.3.8",
    "eslint": "^10.0.2",
    "jest": "^29.7.0",
    "jscpd": "^4.0.8",
    "ts-jest": "^29.1.2",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.3.3"
  }
}
