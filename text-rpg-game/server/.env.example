# 复制为 .env 并填写实际值，生产环境必须修改
# cp .env.example .env

# 服务端口
PORT=3000

# JWT 密钥（生产环境务必使用强随机字符串）
JWT_SECRET=your-secret-key-change-in-production
JWT_EXPIRE=7d

# MongoDB
MONGODB_URI=mongodb://localhost:27017
MONGODB_DATABASE=turn-based-game

# WebSocket 端口（开发时与 API 分离）
WS_PORT=3001

# 生产环境：若 WS 通过反向代理暴露，可设置完整 URL 供前端使用
# WS_URL=wss://your-domain.com/ws

# CORS 允许的域名（逗号分隔，生产环境必须设置）
# 不设置时：开发模式允许所有，生产模式拒绝跨域
# CORS_ORIGINS=https://your-domain.com,https://www.your-domain.com
