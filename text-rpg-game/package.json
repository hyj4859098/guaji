{
  "name": "text-rpg-game",
  "private": true,
  "description": "文字回合制挂机游戏",
  "scripts": {
    "test:full": "node scripts/test-all.js",
    "pre-release": "node scripts/pre-release-check.js",
    "pre-release:no-e2e": "node scripts/pre-release-check.js --skip-e2e",
    "pre-release:full": "node scripts/pre-release-check.js --full-e2e",
    "test:full:skip-api": "node scripts/test-all.js --skip-api",
    "lint:client": "npx eslint client -c eslint.client.config.js",
    "e2e": "cross-env MONGODB_DATABASE=turn-based-game-test playwright test --workers=16 --reporter=line",
    "e2e:retry": "cross-env MONGODB_DATABASE=turn-based-game-test playwright test --last-failed --workers=4 --reporter=line",
    "e2e:quick": "cross-env MONGODB_DATABASE=turn-based-game-test playwright test auth.spec.js gameplay.spec.js -g \"打开首页|注册新用户|登录并创建角色|完整流程\"",
    "e2e:auth": "playwright test auth.spec.js",
    "e2e:gameplay": "playwright test gameplay.spec.js",
    "e2e:multi": "playwright test gameplay-multi.spec.js",
    "e2e:auth:首页": "playwright test auth.spec.js -g \"打开首页\"",
    "e2e:auth:注册": "playwright test auth.spec.js -g \"注册新用户\"",
    "e2e:auth:登录": "playwright test auth.spec.js -g \"登录并创建角色\"",
    "e2e:完整流程": "playwright test gameplay.spec.js -g \"完整流程\"",
    "e2e:Boss": "playwright test gameplay.spec.js -g \"Boss 战斗\"",
    "e2e:技能": "playwright test gameplay.spec.js -g \"技能学习与装备\"",
    "e2e:装备穿戴": "playwright test gameplay.spec.js -g \"装备穿戴\"",
    "e2e:聊天": "playwright test gameplay.spec.js -g \"聊天\"",
    "e2e:被踢下线": "playwright test auth.spec.js -g \"被踢下线\"",
    "e2e:拍卖购买": "playwright test gameplay-multi.spec.js -g \"拍卖购买\"",
    "e2e:PVP": "playwright test gameplay-multi.spec.js -g \"PVP\"",
    "e2e:交易": "playwright test gameplay-multi.spec.js -g \"交易\"",
    "e2e:install": "playwright install chromium"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "cross-env": "^10.1.0",
    "eslint": "^10.0.2",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.2",
    "ws": "^8.14.2"
  }
}
