# 部署目标服务器（SSH 连接串）
# 格式: user@host，例如 root@120.26.0.177 或 root@myserver.com
# 所有 .bat、.ps1 部署脚本均使用此变量，未设置时默认 root@120.26.0.177
#
# 使用方法:
#   Windows: 在运行 .bat 前执行 set DEPLOY_SERVER=root@你的服务器IP
#            或创建 .env.deploy 并在此目录执行前 source/加载
#   PowerShell: $env:DEPLOY_SERVER = "root@你的服务器IP"
#
DEPLOY_SERVER=root@120.26.0.177
